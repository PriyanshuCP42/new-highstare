<script src="{{ 'highstare-hero.js' | asset_url }}" defer></script>

<section
  class="hs-hero section"
  style="--hs-hero-bg: {{ section.settings.background_color }};"
  aria-label="{{ section.settings.accessibility_label | escape }}"
>
  <highstare-hero-slideshow
    class="hs-hero__slideshow"
    data-autoplay="{{ section.settings.autoplay_speed | times: 1000 }}"
  >
    <div class="hs-hero__viewport">
      {% if section.blocks.size > 1 %}
        <button type="button" class="hs-hero__arrow hs-hero__arrow--prev" data-prev aria-label="Previous slide">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <button type="button" class="hs-hero__arrow hs-hero__arrow--next" data-next aria-label="Next slide">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      {% endif %}

      {% for block in section.blocks %}
        {% liquid
          assign image_src = blank
          assign image = block.settings.image
          if image == blank and block.settings.fallback_asset != blank
            assign image_src = block.settings.fallback_asset | asset_url
            assign image_alt = block.settings.title
          elsif image != blank
            assign image_src = image | image_url: width: 1200
            assign image_alt = image.alt | default: block.settings.title
          endif
        %}

        {% if image_src != blank %}
          <article
            class="hs-hero__slide{% if forloop.first %} is-active{% endif %}"
            data-slide
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="hs-hero__slide-inner">
              <div class="hs-hero__media">
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="hs-hero__media-link" tabindex="-1" aria-hidden="true">
                {% endif %}
                <img
                  class="hs-hero__image"
                  src="{{ image_src }}"
                  alt="{{ image_alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="1200"
                  height="1400"
                >
                {% if block.settings.link != blank %}
                  </a>
                {% endif %}
              </div>

              <div class="hs-hero__content">
                {% if block.settings.eyebrow != blank %}
                  <p class="hs-hero__eyebrow">{{ block.settings.eyebrow }}</p>
                {% endif %}
                {% if block.settings.title != blank %}
                  <h2 class="hs-hero__title">{{ block.settings.title }}</h2>
                {% endif %}
                {% if block.settings.subtitle != blank %}
                  <p class="hs-hero__subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
                {% if block.settings.link != blank and block.settings.button_label != blank %}
                  <a class="hs-hero__cta" href="{{ block.settings.link }}">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </article>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size > 1 %}
        <div class="hs-hero__dots" role="tablist" aria-label="Slide navigation">
          {% for block in section.blocks %}
            <button
              type="button"
              class="hs-hero__dot{% if forloop.first %} is-active{% endif %}"
              data-dot
              role="tab"
              aria-label="Slide {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            ></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </highstare-hero-slideshow>
</section>

{% stylesheet %}
  .hs-hero {
    background: #ffffff;
    overflow: hidden;
  }

  .hs-hero__slideshow {
    display: block;
    width: 100%;
    position: relative;
  }

  .hs-hero__viewport {
    position: relative;
    min-height: clamp(620px, 85vh, 900px);
    background: var(--hs-hero-bg, transparent);
  }

  .hs-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.55s ease, visibility 0.55s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 56px 56px;
    background: transparent;
  }

  .hs-hero__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .hs-hero__slide-inner {
    width: min(680px, 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 18px;
  }

  .hs-hero__media {
    width: 100%;
    max-width: 560px;
  }

  .hs-hero__media-link {
    display: block;
    text-decoration: none;
  }

  .hs-hero__image {
    width: 100%;
    height: auto;
    max-height: clamp(400px, 65vh, 640px);
    object-fit: contain;
    object-position: center;
    display: block;
    mix-blend-mode: multiply;
  }

  .hs-hero__content {
    max-width: 420px;
  }

  .hs-hero__eyebrow {
    margin: 0 0 6px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.42);
  }

  .hs-hero__title {
    margin: 0 0 6px;
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .hs-hero__subtitle {
    margin: 0 0 18px;
    font-size: 13px;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.5);
  }

  .hs-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 148px;
    padding: 13px 28px;
    background: #000;
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .hs-hero__cta:hover,
  .hs-hero__cta:focus-visible {
    opacity: 0.82;
  }

  .hs-hero__arrow {
    position: absolute;
    top: 42%;
    transform: translateY(-50%);
    z-index: 3;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    opacity: 0.35;
    transition: opacity 0.2s ease;
  }

  .hs-hero__arrow--prev { left: clamp(8px, 2vw, 24px); }
  .hs-hero__arrow--next { right: clamp(8px, 2vw, 24px); }

  .hs-hero__arrow:hover,
  .hs-hero__arrow:focus-visible {
    opacity: 1;
  }

  .hs-hero__arrow svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: #000;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hs-hero__dots {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .hs-hero__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: rgba(0, 0, 0, 0.15);
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .hs-hero__dot.is-active {
    background: #000;
    transform: scale(1.2);
  }

  @media (max-width: 749px) {
    .hs-hero__viewport {
      min-height: clamp(540px, 75vh, 720px);
      padding-bottom: 0;
    }

    .hs-hero__slide {
      padding: 24px 20px 52px;
    }

    .hs-hero__arrow {
      display: none;
    }

    .hs-hero__image {
      max-height: clamp(320px, 50vh, 480px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hs-hero__slide {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
