<style>
  .hs-marquee-icon {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
    margin-right: 6px;
    margin-top: -2px; /* Slight optical adjustment */
  }
  .hs-marquee-bar__item {
    display: inline-flex;
    align-items: center;
  }
</style>

<div
  class="hs-marquee-bar"
  style="--hs-marquee-bg: {{ section.settings.background_color }}; --hs-marquee-color: {{ section.settings.text_color }}; --hs-marquee-speed: {{ section.settings.speed }}s;"
  aria-label="Store announcements"
>
  <div class="hs-marquee-bar__track">
    {% capture marquee_content %}
      {% for block in section.blocks %}
        <span class="hs-marquee-bar__item" {{ block.shopify_attributes }}>
          {%- case block.settings.icon -%}
            {%- when 'shipping' -%}
              <span class="hs-marquee-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20">
                  <path fill="#2ECA7F" d="M21 16H3V8h13l4 4v4z"/>
                  <path fill="#1A9C5E" d="M16 8v8h5v-4l-4-4h-1z"/>
                  <circle fill="#34495E" cx="6.5" cy="17.5" r="2.5"/>
                  <circle fill="#34495E" cx="16.5" cy="17.5" r="2.5"/>
                  <circle fill="#F1C40F" cx="16.5" cy="17.5" r="1"/>
                  <circle fill="#F1C40F" cx="6.5" cy="17.5" r="1"/>
                </svg>
              </span>
            {%- when 'camera' -%}
              <span class="hs-marquee-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20">
                  <path fill="#9B59B6" d="M21 7h-4.2l-1.4-2.8h-6.8L7.2 7H3c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2z"/>
                  <circle fill="#F1C40F" cx="12" cy="14" r="5"/>
                  <circle fill="#F39C12" cx="12" cy="14" r="3"/>
                </svg>
              </span>
            {%- when 'returns' -%}
              <span class="hs-marquee-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20">
                  <path fill="#3498DB" d="M12 4V1L7 6l5 5V8c3.3 0 6 2.7 6 6s-2.7 6-6 6-6-2.7-6-6H4c0 4.4 3.6 8 8 8s8-3.6 8-8-3.6-8-8-8z"/>
                  <circle fill="#2ECC71" cx="12" cy="14" r="4"/>
                  <path fill="#FFFFFF" d="M11 15.5l-2-2 1-1 1 1 2.5-2.5 1 1-3.5 3.5z"/>
                </svg>
              </span>
          {%- endcase -%}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="hs-marquee-bar__link">{{ block.settings.text }}</a>
          {% else %}
            {{ block.settings.text }}
          {% endif %}
        </span>
        <span class="hs-marquee-bar__dot" aria-hidden="true">✦</span>
      {% endfor %}
    {% endcapture %}

    {% if marquee_content != blank %}
      {% for i in (1..6) %}
        <span class="hs-marquee-bar__set" {% unless forloop.first %}aria-hidden="true"{% endunless %}>{{ marquee_content }}</span>
      {% endfor %}
    {% else %}
      {% assign fallback = 'Free delivery on all prepaid orders ✦ Record unboxing video on delivery ✦ Easy exchange within 3 days ✦ ' %}
      {% for i in (1..6) %}
        <span class="hs-marquee-bar__set" {% unless forloop.first %}aria-hidden="true"{% endunless %}>{{ fallback }}</span>
      {% endfor %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "HIGHSTARE Marquee Bar",
  "tag": "section",
  "class": "hs-marquee-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "max_blocks": 6,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds)",
      "min": 18,
      "max": 50,
      "step": 1,
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "shipping", "label": "Shipping Truck" },
            { "value": "camera", "label": "Camera" },
            { "value": "returns", "label": "Returns Arrow" }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free delivery on all prepaid orders"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIGHSTARE Marquee Bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "icon": "shipping",
            "text": "Free delivery on all prepaid orders"
          }
        },
        {
          "type": "message",
          "settings": {
            "icon": "camera",
            "text": "Record unboxing video on delivery"
          }
        },
        {
          "type": "message",
          "settings": {
            "icon": "returns",
            "text": "Easy exchange within 3 days"
          }
        }
      ]
    }
  ]
}
{% endschema %}
