{{ 'highstare-home.css' | asset_url | stylesheet_tag }}

<section class="highstare-trust-bar section" aria-label="Store benefits">
  <div class="highstare-trust-bar__inner">
    {% for block in section.blocks %}
      <button
        type="button"
        class="highstare-trust-bar__item"
        {{ block.shopify_attributes }}
        {% if block.settings.modal_text != blank %}
          onclick="this.nextElementSibling.showModal()"
        {% endif %}
      >
        {% case block.settings.icon %}
          {% when 'shield' %}
            <svg class="highstare-trust-bar__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z"/>
              <path d="M9.5 12.5l1.8 1.8 3.7-3.7"/>
            </svg>
          {% when 'return' %}
            <svg class="highstare-trust-bar__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 7H4v3"/>
              <path d="M4 10a8 8 0 1 1 2 5.7"/>
            </svg>
          {% when 'users' %}
            <svg class="highstare-trust-bar__icon" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="8" r="3"/>
              <path d="M5 20c0-3.3 3.1-5 7-5s7 1.7 7 5"/>
            </svg>
        {% endcase %}
        <span class="highstare-trust-bar__label">{{ block.settings.label }}</span>
      </button>

      {% if block.settings.modal_text != blank %}
        <dialog class="highstare-trust-bar__dialog" style="max-width: 480px; padding: 24px; border: 1px solid #eee; border-radius: 8px;">
          <form method="dialog">
            <button type="submit" aria-label="Close" style="float: right; border: 0; background: transparent; cursor: pointer;">✕</button>
          </form>
          <p style="margin: 16px 0 0; line-height: 1.6;">{{ block.settings.modal_text }}</p>
        </dialog>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "HIGHSTARE Trust Bar",
  "tag": "section",
  "class": "highstare-trust-bar-section",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "return", "label": "Return" },
            { "value": "users", "label": "Users" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Protect your order"
        },
        {
          "type": "textarea",
          "id": "modal_text",
          "label": "Popup text (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIGHSTARE Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "label": "Protect your order",
            "modal_text": "Record a quick unboxing video upon delivery. It helps ensure a smooth resolution in rare cases."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "return",
            "label": "Easy exchange & return",
            "modal_text": "Enjoy easy returns or exchanges within 3 days of delivery. Reach out on WhatsApp and our team will assist you within 24–48 hours."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "users",
            "label": "Trusted customers",
            "modal_text": "Trusted by a growing community for quality fabrics, precise detailing, and a refined streetwear identity."
          }
        }
      ]
    }
  ]
}
{% endschema %}
