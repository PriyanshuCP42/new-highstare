

{%- doc -%}
  This block is used to display the accelerated checkout button.
  Intended for product-form.liquid block.

  @param {string} can_add_to_cart - Whether the product can be added to the cart
  @param form_obj - The form object

  @example
  {% content_for 'block', type: 'accelerated-checkout', id: 'accelerated-checkout', can_add_to_cart: can_add_to_cart, form_obj: form %}
{%- enddoc -%}

{% liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
%}

{% capture accelerated_checkout_button %}
  {% if product != blank %}
    <button type="button" 
            onclick="hsDirectCheckoutAbsolute(this)"
            class="shopify-payment-button__button shopify-payment-button__button--unbranded hs-direct-checkout-btn"
            style="display:block;width:100%;background-color:#000;color:#fff;padding:15px;border-radius:4px;font-weight:bold;cursor:pointer;border:none;font-size:16px;letter-spacing:0.5px;margin-top:10px;">
      Buy it now
    </button>
    <script>
      function hsDirectCheckoutAbsolute(btn) {
        if (btn.disabled) return false;
        
        btn.innerHTML = 'Adding to cart...';
        btn.disabled = true;
        btn.style.opacity = '0.7';
        
        try {
          var form = document.querySelector('form[data-type="add-to-cart-form"]');
          var variantInput = form ? form.querySelector('input[name="id"]') : null;
          var variantId = variantInput ? variantInput.value : '{{ product.selected_or_first_available_variant.id }}';
          
          var quantityInput = form ? form.querySelector('input[name="quantity"]') : null;
          var quantity = quantityInput ? parseInt(quantityInput.value) || 1 : 1;
          
          var url = window.Shopify.routes.root + 'cart/add.js';
          var data = JSON.stringify({ items: [{ id: variantId, quantity: quantity }] });
          
          // Use SYNCHRONOUS XMLHttpRequest (third parameter is false)
          // This freezes the main thread until the request completes.
          // This guarantees that window.location.href executes in the SAME event loop
          // as the user's physical click, completely bypassing Instagram WebView's
          // strict async-navigation and popup blockers.
          var xhr = new XMLHttpRequest();
          xhr.open('POST', url, false);
          xhr.setRequestHeader('Content-Type', 'application/json');
          xhr.send(data);
          
          // Redirect immediately after synchronous request finishes
          var cartUrl = window.location.origin + window.Shopify.routes.root + 'cart';
          window.location.assign(cartUrl);
          
        } catch(e) {
          console.error('JS error:', e);
          var cartUrl = window.location.origin + window.Shopify.routes.root + 'cart';
          window.location.assign(cartUrl);
        }
        return false;
      }
    </script>
  {% endif %}
{% endcapture %}

{% if accelerated_checkout_button != blank %}
  <div
    class="accelerated-checkout-block"
    ref="acceleratedCheckoutButtonContainer"
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
    {% unless can_add_to_cart %}
      hidden
    {% endunless %}
  >
    {{ accelerated_checkout_button }}
  </div>
{% endif %}

{% render 'buy-buttons-styles' %}

{% schema %}
{
  "name": "t:names.accelerated_checkout",
  "tag": null
}
{% endschema %}
