

{%- doc -%}
  This block is used to display the accelerated checkout button.
  Intended for product-form.liquid block.

  @param {string} can_add_to_cart - Whether the product can be added to the cart
  @param form_obj - The form object

  @example
  {% content_for 'block', type: 'accelerated-checkout', id: 'accelerated-checkout', can_add_to_cart: can_add_to_cart, form_obj: form %}
{%- enddoc -%}

{% liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
%}

{% capture accelerated_checkout_button %}
  {% if product != blank and form_obj != blank %}
    <!-- Container for the standard dynamic button (Desktop / Normal Browsers) -->
    <div id="hs-standard-checkout-{{ block.id }}" style="display: none;">
      {{ form_obj | payment_button }}
    </div>

    <!-- Container for the Instagram-safe native button (WebView only) -->
    <div id="hs-insta-checkout-{{ block.id }}" style="display: none;">
      <button
        type="button"
        id="hs-buy-now-btn-{{ block.id }}"
        class="shopify-payment-button__button shopify-payment-button__button--unbranded"
      >
        Buy it now
      </button>
    </div>

    <script>
      (function() {
        var ua = navigator.userAgent || navigator.vendor || window.opera;
        var isInstagram = (ua.indexOf('Instagram') > -1) || (ua.indexOf('FBAN') > -1) || (ua.indexOf('FBAV') > -1);
        
        var standardContainer = document.getElementById('hs-standard-checkout-{{ block.id }}');
        var instaContainer = document.getElementById('hs-insta-checkout-{{ block.id }}');
        var instaBtn = document.getElementById('hs-buy-now-btn-{{ block.id }}');

        if (isInstagram) {
          // Show native button on Instagram to bypass Magic Checkout lockup
          if (instaContainer) instaContainer.style.display = 'block';
          
          if (instaBtn) {
            instaBtn.addEventListener('click', function(e) {
              e.preventDefault();
              // Find the EXACT form that this button belongs to
              var form = instaBtn.closest('form');
              var variantId = '{{ product.selected_or_first_available_variant.id }}';
              var qty = '1';
              
              if (form) {
                var variantInput = form.querySelector('input[name="id"]');
                var qtyInput = form.querySelector('input[name="quantity"]');
                if (variantInput) variantId = variantInput.value;
                if (qtyInput) qty = qtyInput.value;
              }
              
              // Direct POST form submit bypasses all JS/fetch blocks in Instagram
              var submitForm = document.createElement('form');
              submitForm.method = 'POST';
              submitForm.action = '/cart/add';
              
              var idInput = document.createElement('input');
              idInput.type = 'hidden'; idInput.name = 'id'; idInput.value = variantId;
              
              var qtyInputNode = document.createElement('input');
              qtyInputNode.type = 'hidden'; qtyInputNode.name = 'quantity'; qtyInputNode.value = qty;
              
              var returnInput = document.createElement('input');
              returnInput.type = 'hidden'; returnInput.name = 'return_to'; returnInput.value = '/checkout';
              
              submitForm.appendChild(idInput);
              submitForm.appendChild(qtyInputNode);
              submitForm.appendChild(returnInput);
              document.body.appendChild(submitForm);
              submitForm.submit();
            });
          }
        } else {
          // Show standard Shopify button (which Razorpay hooks into) on normal browsers
          if (standardContainer) standardContainer.style.display = 'block';
        }
      })();
    </script>
  {% endif %}
{% endcapture %}

{% if accelerated_checkout_button != blank %}
  <div
    class="accelerated-checkout-block"
    ref="acceleratedCheckoutButtonContainer"
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
    {% unless can_add_to_cart %}
      hidden
    {% endunless %}
  >
    {{ accelerated_checkout_button }}
  </div>
{% endif %}

{% render 'buy-buttons-styles' %}

{% schema %}
{
  "name": "t:names.accelerated_checkout",
  "tag": null
}
{% endschema %}
