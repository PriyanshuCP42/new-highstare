<div class="product-trust-badges-wrapper">
  <p class="trust-badge-title">Guaranteed Safe & Secure Checkout</p>
  
  <div class="product-trust-badges">
    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28">
          <path fill="#2ECA7F" d="M21 16H3V8h13l4 4v4z"/>
          <path fill="#1A9C5E" d="M16 8v8h5v-4l-4-4h-1z"/>
          <circle fill="#34495E" cx="6.5" cy="17.5" r="2.5"/>
          <circle fill="#34495E" cx="16.5" cy="17.5" r="2.5"/>
          <circle fill="#F1C40F" cx="16.5" cy="17.5" r="1"/>
          <circle fill="#F1C40F" cx="6.5" cy="17.5" r="1"/>
        </svg>
      </div>
      <span class="trust-badge__text">Free Shipping</span>
    </div>
    
    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28">
          <path fill="#F1C40F" d="M12 2l9 4v6c0 5.5-4 10-9 12-5-2-9-6.5-9-12V6l9-4z"/>
          <path fill="#F39C12" d="M12 2v20c5-2 9-6.5 9-12V6l-9-4z"/>
          <path fill="#FFFFFF" d="M10.5 15.5L7 12l1.4-1.4 2.1 2.1 5.1-5.1L17 9l-6.5 6.5z"/>
        </svg>
      </div>
      <span class="trust-badge__text">Secure Checkout</span>
    </div>

    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28">
          <path fill="#E74C3C" d="M6 10l3 12 3-3 3 3 3-12H6z"/>
          <circle fill="#F1C40F" cx="12" cy="9" r="7"/>
          <circle fill="#F39C12" cx="12" cy="9" r="5"/>
          <path fill="#FFFFFF" d="M12 6.5l1.5 3 3.5.5-2.5 2.5.5 3.5-3-1.5-3 1.5.5-3.5-2.5-2.5 3.5-.5z"/>
        </svg>
      </div>
      <span class="trust-badge__text">100% Quality</span>
    </div>

    <div class="trust-badge">
      <div class="trust-badge__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28">
          <path fill="#2ECC71" d="M4 6h16c1.1 0 2 .9 2 2v8c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V8c0-1.1.9-2 2-2z"/>
          <circle fill="#F1C40F" cx="12" cy="12" r="3.5"/>
          <path fill="#1A9C5E" d="M2 8v8c0 1.1.9 2 2 2h2v-12H4c-1.1 0-2 .9-2 2zm18-2h-2v12h2c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
          <path fill="#F39C12" d="M12 9.5c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5z"/>
        </svg>
      </div>
      <span class="trust-badge__text">COD Available</span>
    </div>
  </div>

  <div class="secure-checkout-badge">
    <div class="secure-checkout-header">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
        <path fill="#27ae60" d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
      </svg>
      <span>100% SECURE PAYMENT GUARANTEED</span>
    </div>
    <div class="secure-checkout-icons">
      {{ 'master' | payment_type_svg_tag: class: 'sc-payment-icon' }}
      {{ 'rupay' | payment_type_svg_tag: class: 'sc-payment-icon' }}
      {{ 'upi' | payment_type_svg_tag: class: 'sc-payment-icon' }}
      {{ 'google_pay' | payment_type_svg_tag: class: 'sc-payment-icon' }}
    </div>
  </div>
</div>

<style>
  .product-trust-badges-wrapper {
    margin-top: 24px;
    margin-bottom: 24px;
    padding: 20px;
    background: rgb(var(--color-background-secondary), 0.5);
    border-radius: var(--style-border-radius);
    border: 1px solid rgb(var(--color-border));
    text-align: center;
  }

  .trust-badge-title {
    font-size: 13px;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin-bottom: 16px;
    margin-top: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .product-trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-bottom: 20px;
  }
  
  .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex: 1 1 calc(25% - 12px);
    min-width: 70px;
    gap: 8px;
  }
  
  .trust-badge__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .trust-badge__text {
    font-size: 11px;
    line-height: 1.2;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .secure-checkout-badge {
    margin-top: 24px;
    padding: 14px;
    background-color: #f7f9fa;
    border: 1px solid #e1e3e5;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .secure-checkout-header {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #2c3e50;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.5px;
  }

  .secure-checkout-header svg {
    width: 16px;
    height: 16px;
    color: #27ae60;
  }

  .secure-checkout-icons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .sc-payment-icon {
    width: 55px;
    height: 35px;
  }

  .trust-payment-icon-custom svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 749px) {
    .trust-badge {
      flex: 1 1 calc(50% - 12px);
    }
  }
</style>
